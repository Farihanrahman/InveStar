# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_OMS_API_BASE_URL=oms-investar-authapi.dev.sandbox3000.com
VITE_OMS_APP_ID=InvestarOMS
VITE_OMS_API_VERSION=v1

# Supabase Edge Functions
# Set these as function secrets in Supabase for production.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# AI gateway key used by ai-coach, remit-agent, investar-ai-chat
LOVABLE_API_KEY=your_lovable_api_key

# OMS auth proxy defaults
OMS_API_BASE_URL=oms-investar-authapi.dev.sandbox3000.com
OMS_APP_ID=InvestarOMS
OMS_API_VERSION=v1

# Stellar signing/encryption (required by stellar-* edge functions)
STELLAR_ENCRYPTION_KEY=replace_with_a_strong_random_secret

# Optional custom wallet proxy values
CUSTOM_WALLET_API_URL=https://api.example.com
CUSTOM_WALLET_API_KEY=your_custom_wallet_api_key
